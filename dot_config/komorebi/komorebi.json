{
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/master/schema.json",
  "app_specific_configuration_path": "$Env:USERPROFILE/.config/komorebi/applications.json",
  "cross_monitor_move_behaviour": "Insert",
  "default_workspace_padding": 2,
  "default_container_padding": 2,
  "window_hiding_behaviour": "Cloak",
  "alt_focus_hack": true,
  "mouse_follows_focus": true,

  "border": true,
  "border_width": 2,
  "border_colours": {
    "single": "#4C566A",
    "stack": "#A3BE8C",
    "monocle": "#EBCB8B",
    "unfocused": "#2E3440"
  },
  "animation": {
    "enabled": true,
    "duration": 150,
    "fps": 60,
    "style": "EaseOutExpo"
  },
  "monitors": [
    {
      "workspaces": [
        {
          "name": "1",
          "layout": "BSP"
        },
        {
          "name": "2",
          "layout": "BSP"
        },
        {
          "name": "3",
          "layout": "BSP"
        },
        {
          "name": "4",
          "layout": "BSP"
        },
        {
          "name": "5",
          "layout": "BSP"
        },
        {
          "name": "6",
          "layout": "BSP"
        }
      ]
    }
  ]
}
