{
  // #region Others
  "telemetry.telemetryLevel": "off",
  "diffEditor.ignoreTrimWhitespace": true,
  // #endregion

  // #region Editor
  "editor.guides.bracketPairs": true,
  "editor.linkedEditing": true,
  "editor.stickyScroll.enabled": false,
  "editor.tabSize": 2,
  "editor.wordWrapColumn": 80,
  "editor.wordWrap": "on",
  "editor.cursorBlinking": "expand",
  "editor.fontLigatures": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.smoothScrolling": true,
  "editor.mouseWheelZoom": true,
  "editor.detectIndentation": false,
  "editor.renderWhitespace": "all",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.minimap.enabled": false,
  "editor.hover.delay": 1000,
  "editor.rulers": [80],
  "editor.lineNumbers": "relative",
  "editor.occurrencesHighlight": "off",
  "editor.hideCursorInOverviewRuler": true,
  "editor.wordSeparators": "`~!@#$%^&*()=+[{]}\\|;:'\",.<>/?",
  "editor.renderLineHighlight": "all",
  "editor.cursorSurroundingLines": 8,
  "editor.fontFamily": "'JetBrainsMono Nerd Font', Consolas, 'Courier New', monospace",
  "editor.tokenColorCustomizations": {
    "[*Light*]": {
      "textMateRules": [
        {
          "scope": "ref.matchtext",
          "settings": {
            "foreground": "#000"
          }
        }
      ]
    },
    "[*Dark*]": {
      "textMateRules": [
        {
          "scope": "ref.matchtext",
          "settings": {
            "foreground": "#fff"
          }
        }
      ]
    },
    "textMateRules": []
  },
  // #endregion

  // #region Workbench
  "workbench.colorTheme": "Dracula Theme",
  "workbench.preferredDarkColorTheme": "Dracula Theme",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.startupEditor": "none",
  "workbench.editor.openSideBySideDirection": "right",
  "workbench.tips.enabled": false,
  "workbench.tree.enableStickyScroll": false,
  "workbench.tree.renderIndentGuides": "none",
  "workbench.settings.applyToAllProfiles": [
    "editor.tabSize",
    "editor.detectIndentation",
    "editor.insertSpaces",
    "editor.guides.bracketPairs",
    "editor.linkedEditing",
    "editor.stickyScroll.enabled",
    "editor.wordWrapColumn",
    "editor.wordWrap",
    "editor.cursorBlinking",
    "editor.fontLigatures",
    "editor.bracketPairColorization.enabled",
    "editor.smoothScrolling",
    "editor.mouseWheelZoom",
    "editor.renderWhitespace",
    "editor.cursorSmoothCaretAnimation",
    "editor.minimap.enabled",
    "editor.hover.delay",
    "editor.rulers",
    "editor.lineNumbers",
    "editor.occurrencesHighlight",
    "editor.hideCursorInOverviewRuler",
    "editor.wordSeparators",
    "editor.renderLineHighlight",
    "editor.cursorSurroundingLines",
    "editor.fontFamily",
    "editor.tokenColorCustomizations"
  ],
  "workbench.editorAssociations": {
    "*.copilotmd": "vscode.markdown.preview.editor",
    "*.pdf": "latex-workshop-pdf-hook"
  },
  // #endregion

  // #region Extensions
  "extensions.experimental.affinity": {
    "vscodevim.vim": 1
  },
  // #endregion

  // #region GitHub Copilot
  "github.copilot.enable": {
    "*": false,
    "plaintext": false,
    "markdown": false,
    "scminput": false
  },
  "github.copilot.nextEditSuggestions.enabled": true,
  // #endregion

  // #region React Snippets
  "reactSnippets.settings.importReactOnTop": false,
  // #endregion

  // #region LiveServer
  "liveServer.settings.donotShowInfoMsg": true,
  "liveServer.settings.donotVerifyTags": true,
  // #endregion

  // #region Emmet
  "emmet.preferences": {
    "emmet.includeLanguages": {
      "javascript": "javascriptreact"
    },
    "emmet.triggerExpansionOnTab": true
  },
  // #endregion

  // #region Auto Close Tag
  "auto-close-tag.activationOnLanguage": [
    "mdx"
  ],
  // #endregion

  // #region Material icon theme
  "material-icon-theme.hidesExplorerArrows": true,
  // #endregion

  // #region Files
  "files.exclude": {
    "**/.git": false
  },
  "files.associations": {
    "*.embeddedhtml": "html",
    "*.css": "tailwindcss",
    ".env*": "dotenv"
  },
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.eol": "\n",
  // #endregion

  // #region Explorer
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.compactFolders": false,
  // #endregion

  // #region Git
  "git.openRepositoryInParentFolders": "always",
  "git.autofetch": true,
  "git.enableSmartCommit": true,
  "git.confirmSync": false,
  // #endregion

  // #region Path Intellisense
  "path-intellisense.autoSlashAfterDirectory": true,
  "path-intellisense.autoTriggerNextSuggestion": true,
  "path-intellisense.ignoreTsConfigBaseUrl": true,
  "path-intellisense.showHiddenFiles": true,
  // #endregion

  // #region Window
  "window.autoDetectColorScheme": true,
  // #endregion

  // #region Terminal
  "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font",
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  // #endregion

  // #region HTML
  "html.format.wrapLineLength": 0,
  "html.format.contentUnformatted": "pre,code,textarea",
  "html.format.maxPreserveNewLines": 1,
  "html.format.preserveNewLines": true,
  "html.format.wrapAttributes": "force-expand-multiline",
  // #endregion

  // #region Pretitier / Format
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[markdown]": {
    "editor.defaultFormatter": "yzhang.markdown-all-in-one",
    "editor.wordWrap": "off"
  },
  "[mdx]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.wordWrap": "off"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[scss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascriptreact]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[sql]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "mtxr.sqltools"
  },
  "[python]": {
    "editor.tabSize": 4,
    "editor.rulers": [88],
    "editor.insertSpaces": true,
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.organizeImports": "explicit"
    }
  },
  "[csharp]": {
    "editor.formatOnSave": true,
    "editor.tabSize": 4,
    "editor.defaultFormatter": "ms-dotnettools.csharp"
  },
  "[rust]": {
    "editor.formatOnSave": true,
    "editor.tabSize": 4,
    "editor.defaultFormatter": "rust-lang.rust-analyzer"
  },
  "[shellscript]": {
    "editor.defaultFormatter": "foxundermoon.shell-format",
    "editor.formatOnSave": true,
    "editor.tabSize": 4
  },
  // #endregion

  // #region CSpell
  "cSpell.userWords": [],
  "cSpell.ignoreWords": [],
  "cSpell.language": "en,vi",
  "cSpell.enabledFileTypes": {
    "markdown": false
  },
  // #endregion

  // #region Better Comments
  "better-comments.tags": [
    {
      "tag": "TODO:",
      "color": "#EA580C",
      "strikethrough": false,
      "backgroundColor": "transparent"
    },
    {
      "tag": "FIXME:",
      "color": "#FF2D00",
      "strikethrough": false,
      "backgroundColor": "transparent"
    },
    {
      "tag": "BUG:",
      "color": "#9333EA",
      "strikethrough": false,
      "backgroundColor": "transparent"
    },
    {
      "tag": "HACK:",
      "color": "#C026D3",
      "strikethrough": false,
      "backgroundColor": "transparent"
    },
    {
      "tag": " #region",
      "color": "#2563EB",
      "strikethrough": false,
      "backgroundColor": "transparent"
    },
    {
      "tag": "INFO:",
      "color": "#0EA5E9",
      "strikethrough": false,
      "backgroundColor": "transparent"
    },
    {
      "tag": "IDEA:",
      "color": "#FFF",
      "strikethrough": false,
      "backgroundColor": "#EAB308"
    },
    {
      "tag": "WHY:",
      "color": "#F59E0B",
      "strikethrough": false,
      "backgroundColor": "transparent"
    },
    {
      "tag": "PERF:",
      "color": "#22C55E",
      "strikethrough": false,
      "backgroundColor": "transparent"
    }
  ],
  // #endregion

  // #region Security
  "security.workspace.trust.untrustedFiles": "open",
  // #endregion

  // #region C/C++
  "C_Cpp.default.compilerPath": "C:\\msys64\\ucrt64\\bin\\gcc.exe",
  "C_Cpp.autocompleteAddParentheses": true,
  "C_Cpp.formatting": "clangFormat",
  "C_Cpp.default.includePath": [
    "C:/Program Files/emsdk/upstream/emscripten/system/include"
  ],
  // #endregion

  // #region CodeSnap
  "codesnap.target": "window",
  // #endregion

  // #region JavaScript / TypeScript
  // "js/ts.updateImportsOnFileMove.enabled": "prompt",
  // #endregion

  // #region Tailwindcss
  "tailwindCSS.emmetCompletions": true,
  "tailwindCSS.includeLanguages": {
    "html": "html",
    "javascript": "javascript",
    "css": "css"
  },
  "tailwindCSS.experimental.configFile": null,
  // #endregion

  // #region Markdown
  "markdownlint.config": {
    "default": true,
    "MD033": false,
    "MD041": false,
    "MD060": false,
    "MD056": false,
  },
  // #endregion

  // #region Json
  "json.schemaDownload.enable": true,
  "json.schemaDownload.trustedDomains": {
    "https://aka.ms": true,
    "https://developer.microsoft.com/json-schemas/": true,
    "https://json-schema.org/": true,
    "https://json.schemastore.org/": true,
    "https://raw.githubusercontent.com/": true,
    "https://raw.githubusercontent.com/devcontainers/spec/": true,
    "https://raw.githubusercontent.com/microsoft/vscode/": true,
    "https://schemastore.azurewebsites.net/": true,
    "https://turborepo.dev": true,
    "https://ui.shadcn.com": true,
    "https://www.schemastore.org/": true
  },
  // #endregion

  // #region Chat
  "chat.viewSessions.orientation": "stacked",
  "chat.mcp.serverSampling": {},
  "chat.mcp.discovery.enabled": {
    "claude-desktop": true,
    "windsurf": true,
    "cursor-global": true,
    "cursor-workspace": true
  },
  // #endregion

  // #region DotENV
  "dotenv.enableAutocloaking": false,
  // #endregion

  // #region PHP
  "php.format.codeStyle": "Laravel",
  "php.inlayHints.insertOnDoubleClick": false,
  "php.format.rules.booleanConstantCasing": "lowercase",
  "php.format.rules.spaceAfterUnaryNot": false,
  "php.inlayHints.parameters.enabled": false,
  "php.format.rules.openBraceOnNewLineForBlocks": false,
  "php.format.rules.openBraceOnNewLineForFunctions": false,
  "php.format.rules.openBraceOnNewLineForLambdas": false,
  "php.format.rules.alignConstants": false,
  "php.format.rules.alignEnumCases": false,
  "php.format.rules.openBraceOnNewLineForTypes": false,
  "php.format.rules.keepFunctionsOnOneLine": true,
  "php.format.rules.spaceBeforeColonInControlStatements": false,
  // #endregion

  // #region SQLTools
  "sqltools.connections": [],
  "sqltools.useNodeRuntime": false,
  "sqltools.format": {
    "linesBetweenQueries": 2,
    "reservedWordCase": "upper",
  },
  // #endregion

  // #region Prettier SQL
  "Prettier-SQL.keywordCase": "upper",
  // #endregion

  // #region PHP
  "php.inlayHints.types.return": false,
  "php.format.rules.importSorting": "alphabetic",
  "php.format.rules.callParametersNewLineAfterLeftParen": true,
  "php.format.rules.callParametersNewLineBeforeRightParen": true,
  "php.format.rules.callParametersWrap": "onEveryItem",
  "php.format.rules.arrayInitializersNewLineBeforeFirstElement": true,
  "php.format.rules.arrayInitializersNewLineAfterLastElement": true,
  "php.format.rules.arrayInitializersWrap": "onEveryItem",
  // #endregion

  // #region MSSQL
  "mssql.connectionGroups": [
    {
      "name": "ROOT",
      "id": "7CE6DBAA-33D5-4275-B4D3-09971EC78397"
    }
  ],
  "mssql.connections": [
    {
      "authenticationType": "Integrated",
      "connectTimeout": 30,
      "applicationName": "vscode-mssql",
      "applicationIntent": "ReadWrite",
      "server": "(localdb)\\MSSQLLocalDB",
      "database": "",
      "groupId": "7CE6DBAA-33D5-4275-B4D3-09971EC78397",
      "id": "490E7133-CE70-4DC4-A5E3-785D8D2EAB07",
      "user": "",
      "password": "",
      "commandTimeout": 30,
      "encrypt": "Mandatory",
      "profileSource": 0
    }
  ],
  "mssql.autoDisableNonTSqlLanguageService": true,
  "mssql.format.datatypeCasing": "uppercase",
  "mssql.format.keywordCasing": "uppercase",
  // #endregion

  // #region Black Formatter
  "black-formatter.importStrategy": "fromEnvironment",
  // #endregion

  // #region Pylance
  "python.analysis.autoFormatStrings": true,
  "python.analysis.autoImportCompletions": true,
  // #endregion

  // #region C# & .NET
  "csharpextensions.useFileScopedNamespace": true,
  "dotnet.codeLens.enableReferencesCodeLens": false,
  "dotnet.formatting.organizeImportsOnFormat": true,
  // #endregion

  // #region LaTex Workshop
  "latex-workshop.latex.autoBuild.run": "never",
  "latex-workshop.latex.outDir": "%DIR%/build",
  "latex-workshop.latex.tools": [
    {
      "name": "latexmk-build-folder",
      "command": "latexmk",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-pdf", // ép buộc dùng pdflatex
        "-outdir=%OUTDIR%", // Chỉ định folder output
        "%DOC%"
      ],
      "env": {}
    },
    {
      "name": "latexmk-clean",
      "command": "latexmk",
      "args": [
        "-c", // -c: Xóa file rác, giữ lại PDF (-C là xóa hết)
        "-outdir=%OUTDIR%", // chỉ đúng thư mục build
        "%DOC%"
      ],
      "env": {}
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "🏗️ PDFLaTeX",
      "tools": ["latexmk-build-folder"]
    },
    {
      "name": "🧹 Clean Project",
      "tools": ["latexmk-clean"]
    }
  ],
  // #endregion

  // #region File Tree to Text Generator
  "tree-generator.exclude": {
    "**/.agents/**": true,
    "**/.git/**": true,
    "**/.next/**": true,
    "**/.venv/**": true,
    "**/.vscode/**": true,
    "**/*.log": true,
    "**/*.tmp": true,
    "**/build/**": true,
    "**/coverage/**": true,
    "**/dist/**": true,
    "**/generated/**": true,
    "**/node_modules/**": true,
    "**/.turbo/**": true,
    "**/bin/**": true,
    "**/obj/**": true,
  },
  "tree-generator.defaultDepth": 10,
  // #endregion

  // #region Rust
  "rust-analyzer.inlayHints.chainingHints.enable": true,
  "rust-analyzer.inlayHints.closingBraceHints.enable": false,
  "rust-analyzer.inlayHints.genericParameterHints.const.enable": false,
  "rust-analyzer.inlayHints.parameterHints.enable": false,
  "rust-analyzer.inlayHints.renderColons": false,
  "rust-analyzer.inlayHints.typeHints.enable": false,
  "rust-analyzer.procMacro.enable": true,
  "rust-analyzer.check.command": "clippy",
  "rust-analyzer.check.extraArgs": [
    "--",
    "-W", "clippy::pedantic",
    "-W", "clippy::await_holding_lock",
    "-W", "clippy::unwrap_used"
  ],
  "rust-analyzer.cargo.features": "all",
  "rust-analyzer.workspace.symbol.search.scope": "workspace",
  // #endregion

  // #region Vim
  "vim.leader": "<space>",
  "vim.ignorecase": true,
  "vim.smartcase": true,
  "vim.incsearch": true,
  "vim.hlsearch": true,
  "vim.useSystemClipboard": true,
  "vim.easymotion": true,
  "vim.useCtrlKeys": true,
  // "vim.statusBarColorControl": true,
  // "vim.statusBarColors.normal": ["#8FBCBB", "#434C5E"],
  // "vim.statusBarColors.insert": ["#BF616A", "#ECEFF4"],
  // "vim.statusBarColors.visual": ["#B48EAD", "#ECEFF4"],

  // SKIP KEY
  "vim.handleKeys": {
    "<C-a>": false,
    // "<C-c>": false,
    "<C-f>": false,
    "<C-w>": false,
    "<C-p>": false,
    "<C-k>": false
  },

  // KEYBINDINGS
  "vim.insertModeKeyBindings": [
    { "before": ["<C-c>"], "after": ["<Esc>"] },
  ],
  "vim.normalModeKeyBindingsNonRecursive": [
    { "before": ["H"], "after": ["^"] }, // move to start line
    { "before": ["L"], "after": ["$"] }, // move to end line
    { "before": ["<leader>", "d"], "after": ["d", "d"] },
    { "before": ["<leader>", "n", "h"], "commands": [":nohl"] },
    { "before": ["<leader>", "o"], "after": ["o", "<Esc>"] },
    { "before": ["<leader>", "O"], "after": ["O", "<Esc>"] },
    { "before": ["<leader>", "a"], "after": ["g", "g", "V", "G"] },
    { "before": ["K"], "commands": ["editor.action.showHover"] },
    // { "before": ["<A-j>"], "commands": ["editor.action.moveLinesDownAction"] },
    // { "before": ["<A-k>"], "commands": ["editor.action.moveLinesUpAction"] },
    { "before": ["g", "i"], "commands": ["editor.action.goToImplementation"] }
  ],
  "vim.visualModeKeyBindingsNonRecursive": [
    { "before": [">"], "after": [">", "g", "v"] },
    { "before": ["<"], "after": ["<", "g", "v"] },
    { "before": ["H"], "after": ["^"] },
    { "before": ["L"], "after": ["$", "h"] }
  ],
  // #endregion
}
